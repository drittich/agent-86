{
  "name": "agent-86",
  "publisher": "darcy",
  "displayName": "Agent 86",
  "description": "Local LLM agentic coding assistant with file read/write and terminal approval",
  "version": "0.0.55",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agent86.openPanel",
        "title": "Agent 86: Open Panel"
      },
      {
        "command": "agent86.newSession",
        "title": "Agent 86: New Session",
        "icon": "$(add)"
      },
      {
        "command": "agent86.openSettings",
        "title": "Agent 86: Settings",
        "icon": "$(gear)"
      },
      {
        "command": "agent86.attachFiles",
        "title": "Agent 86: Attach Files"
      },
      {
        "command": "agent86.selectSession",
        "title": "Agent 86: Select Session"
      },
      {
        "command": "agent86.attachActiveEditor",
        "title": "Agent 86: Attach Active Editor"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agent86.newSession",
          "when": "view == agent86.panel",
          "group": "navigation@1"
        },
        {
          "command": "agent86.openSettings",
          "when": "view == agent86.panel",
          "group": "navigation@2"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent86",
          "title": "Agent 86",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agent86": [
        {
          "type": "webview",
          "id": "agent86.panel",
          "name": "Agent 86"
        }
      ],
      "explorer": [
        {
          "id": "agent86FilePicker",
          "name": "File Picker",
          "when": "agent86FilePicker.count > 0"
        }
      ]
    },
    "configuration": {
      "title": "Agent 86",
      "properties": {
        "agent86.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8083/v1",
          "description": "Base URL for the OpenAI-compatible LLM endpoint"
        },
        "agent86.model": {
          "type": "string",
          "default": "qwen35-9b-q4km",
          "description": "Model name to use"
        },
        "agent86.maxContextTokens": {
          "type": "number",
          "default": 32768,
          "description": "Maximum context tokens for the model"
        },
        "agent86.tokenizerModel": {
          "type": "string",
          "default": "Qwen/Qwen3-8B",
          "description": "HuggingFace model ID used to load the tokenizer for accurate token counting (e.g. Qwen/Qwen3-8B). Leave empty to use the char/4 heuristic."
        },
        "agent86.provider": {
          "type": "string",
          "enum": [
            "openai-compatible",
            "anthropic"
          ],
          "default": "openai-compatible",
          "description": "LLM provider type"
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/drittich/agent-86"
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "node esbuild.js --production --bump-version",
    "version:minor": "node esbuild.js --minor"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@huggingface/tokenizers": "^0.1.2",
    "@types/dompurify": "^3.0.5",
    "@vscode/ripgrep": "^1.15.9",
    "dompurify": "^3.3.1",
    "marked": "^17.0.3",
    "openai": "^6.25.0"
  }
}
