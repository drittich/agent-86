{
  "name": "agent-86",
  "publisher": "darcy",
  "displayName": "Agent 86",
  "description": "Local LLM agentic coding assistant with file read/write and terminal approval",
  "version": "0.2.6",
  "engines": {
    "vscode": "^1.111.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:agent86.panel"
  ],
  "type": "module",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agent86.openPanel",
        "title": "Open Panel"
      },
      {
        "command": "agent86.newSession",
        "title": "New Session",
        "icon": "$(add)"
      },
      {
        "command": "agent86.openSettings",
        "title": "Settings",
        "icon": "$(gear)"
      },
      {
        "command": "agent86.attachFiles",
        "title": "Attach Files"
      },
      {
        "command": "agent86.selectSession",
        "title": "History",
        "icon": "$(history)"
      },
      {
        "command": "agent86.attachActiveEditor",
        "title": "Attach Active Editor"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agent86.newSession",
          "when": "view == agent86.panel",
          "group": "navigation@1"
        },
        {
          "command": "agent86.selectSession",
          "when": "view == agent86.panel",
          "group": "navigation@2"
        },
        {
          "command": "agent86.openSettings",
          "when": "view == agent86.panel",
          "group": "navigation@3"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agent86",
          "title": "Agent 86",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "agent86": [
        {
          "type": "webview",
          "id": "agent86.panel",
          "name": "Agent 86"
        }
      ],
      "explorer": [
        {
          "id": "agent86FilePicker",
          "name": "File Picker",
          "when": "agent86FilePicker.count > 0"
        }
      ]
    },
    "configuration": {
      "title": "Agent 86",
      "properties": {
        "agent86.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8083/v1",
          "description": "Base URL for the OpenAI-compatible LLM endpoint"
        },
        "agent86.model": {
          "type": "string",
          "default": "qwen35-9b-q4km",
          "description": "Model name to use"
        },
        "agent86.maxContextTokens": {
          "type": "number",
          "default": 32768,
          "description": "Maximum context tokens for the model"
        },
        "agent86.provider": {
          "type": "string",
          "enum": [
            "openai-compatible",
            "anthropic"
          ],
          "default": "openai-compatible",
          "description": "LLM provider type"
        },
        "agent86.braveApiKey": {
          "type": "string",
          "default": "",
          "description": "Brave Search API key for the web_search tool. Can also be set via the BRAVE_API_KEY environment variable."
        },
        "agent86.maxToolRounds": {
          "type": "number",
          "default": 40,
          "minimum": 1,
          "description": "Maximum number of tool-calling rounds per inference cycle before the model is asked to produce a final answer."
        },
        "agent86.modelTier": {
          "type": "string",
          "enum": [
            "small",
            "balanced",
            "high"
          ],
          "default": "balanced",
          "description": "Model tier for tool selection policy. 'small' enforces strict search-first with aggressive recovery (9B-class models). 'balanced' is the default for 35B-class models. 'high' allows broader exploration for capable hosted models."
        },
        "agent86.providers": {
          "type": "array",
          "default": [],
          "description": "List of LLM provider configurations for multi-provider support",
          "items": {
            "type": "object",
            "required": [
              "name",
              "baseUrl",
              "model",
              "toolUse",
              "context"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Display name for this provider"
              },
              "baseUrl": {
                "type": "string",
                "description": "Base URL for the OpenAI-compatible endpoint"
              },
              "model": {
                "type": "string",
                "description": "Model name to use"
              },
              "apiKey": {
                "type": "string",
                "description": "API key (optional, defaults to 'local')"
              },
              "toolUse": {
                "type": "boolean",
                "default": true,
                "description": "Whether to enable tool use for this provider"
              },
              "context": {
                "type": "number",
                "default": 32768,
                "description": "Context window size in tokens"
              }
            }
          }
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/drittich/agent-86"
  },
  "scripts": {
    "build": "node esbuild.cjs",
    "watch": "node esbuild.cjs --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "node esbuild.cjs --production --bump-version",
    "version:minor": "node esbuild.cjs --minor",
    "package": "npm install && npm run typecheck && vsce package"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.54",
    "@ai-sdk/openai": "^3.0.39",
    "@ai-sdk/openai-compatible": "^2.0.33",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@types/dompurify": "^3.0.5",
    "@vscode/ripgrep": "^1.15.9",
    "ai": "^6.0.111",
    "dompurify": "^3.3.1",
    "marked": "^17.0.3",
    "openai": "^6.25.0"
  }
}
