{
  "name": "agent-86",
  "publisher": "darcy",
  "displayName": "Agent 86",
  "description": "Local LLM agentic coding assistant with file read/write and terminal approval",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentic.openPanel",
        "title": "Agent 86: Open Panel"
      },
      {
        "command": "agentic.newSession",
        "title": "Agent 86: New Session"
      },
      {
        "command": "agentic.attachFiles",
        "title": "Agent 86: Attach Files"
      },
      {
        "command": "agentic.selectSession",
        "title": "Agent 86: Select Session"
      },
      {
        "command": "agentic.attachActiveEditor",
        "title": "Agent 86: Attach Active Editor"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agenticCoder",
          "title": "Agent 86",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "agenticCoder": [
        {
          "type": "webview",
          "id": "agenticCoder.panel",
          "name": "Agent 86"
        }
      ],
      "explorer": [
        {
          "id": "agenticFilePicker",
          "name": "File Picker",
          "when": "agenticFilePicker.count > 0"
        }
      ]
    },
    "configuration": {
      "title": "Agent 86",
      "properties": {
        "agentCoder.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8083/v1",
          "description": "Base URL for the OpenAI-compatible LLM endpoint"
        },
        "agentCoder.model": {
          "type": "string",
          "default": "OpenAI-20B-NEO-CODEPlus-Uncensored-IQ4_NL.gguf",
          "description": "Model name to use"
        },
        "agentCoder.maxContextTokens": {
          "type": "number",
          "default": 16384,
          "description": "Maximum context tokens for the model"
        },
        "agentCoder.provider": {
          "type": "string",
          "enum": [
            "openai-compatible",
            "anthropic"
          ],
          "default": "openai-compatible",
          "description": "LLM provider type"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "node esbuild.js --production"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.3.1",
    "marked": "^17.0.3",
    "openai": "^4.28.0"
  }
}
